{
  "name": "cs-api-client",
  "version": "0.1.0",
  "description": "TypeScript client for OGC API Connected Systems (Part 1 & Part 2)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mqtt": {
      "types": "./dist/mqtt.d.ts",
      "import": "./dist/mqtt.js"
    },
    "./rxjs": {
      "types": "./dist/rxjs.d.ts",
      "import": "./dist/rxjs.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "mqtt": "^5",
    "rxjs": "^7"
  },
  "peerDependenciesMeta": {
    "mqtt": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "mqtt": "^5.15.1",
    "rxjs": "^7.8.2",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
